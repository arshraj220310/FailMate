rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Failed projects — public read, logged-in users can add/update
    match /projects/{projectId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Comments per project
    match /comments/{projectId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // User profile — only the signed-in user can read/write their doc
    match /users/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // App metadata (seed flag)
    match /meta/{doc} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Global terminal feed
    match /global/{doc} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }
  }
}
